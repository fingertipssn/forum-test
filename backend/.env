# Database
# asyncpg = driver async para FastAPI
DATABASE_URL=postgresql+asyncpg://postgres:1234@localhost:5432/discourse
# psycopg (v3 binary) = driver sync para Celery workers
DATABASE_URL_SYNC=postgresql+psycopg://postgres:1234@localhost:5432/discourse

# Azure AD / EntraID
AZURE_AD_TENANT_ID=fe990d52-55f3-437e-9b9a-7192d2f17c9f
AZURE_AD_CLIENT_ID=f55271c9-f468-4a6d-a7fa-576b96b6bdeb
AZURE_AD_AUDIENCE=api://f55271c9-f468-4a6d-a7fa-576b96b6bdeb

# App
APP_NAME=Discuss Bancolombia
CORS_ORIGINS=["http://localhost:4200"]
DEBUG=false

# Azure AD real — DEV_MODE desactivado
DEV_MODE=false
DEV_JWT_SECRET=change-this-secret-before-production

# Celery / Redis (poner CELERY_ENABLED=false en local para no necesitar Redis)
CELERY_ENABLED=false
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Upload storage (local path)
UPLOADS_PATH=./uploads
SITE_BASE_URL=http://localhost:8000
